# BEGIN activechain-kanalen
kanalen.activechain.dev {
	header {
		Cache-Control "no-store"
		Content-Type "text/plain; charset=utf-8"
		X-Content-Type-Options "nosniff"
	}
	respond "ActiveChain Kanalen — developmental network infrastructure. No security audit has been completed. Do not use it for value you are unwilling to lose. RPC: rpc.kanalen.activechain.dev:443" 200
}
# END activechain-kanalen
