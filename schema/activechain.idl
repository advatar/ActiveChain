// ActiveChain canonical schema draft 1.
//
// This source is normative input to future generators. Until generators exist,
// P-001 and the hand-written Rust implementation MUST agree with this file.

namespace activechain.protocol;

type Digest384 = bytes[48];

newtype ObjectId = Digest384;
newtype PrincipalId = Digest384;
newtype AuthenticatorId = Digest384;
newtype ActionId = Digest384;
newtype CapabilityId = Digest384;
newtype CredentialId = Digest384;
newtype PackageId = Digest384;
newtype JobId = Digest384;
newtype TransactionId = Digest384;

type Height = u64;
type Epoch = u64;
type Round = u64;
type Amount = u128;
type ResourceUnits = u128;
type Timestamp = u64;

enum PrincipalKind : u8 {
    Human = 0;
    Organization = 1;
    Device = 2;
    Service = 3;
    Agent = 4;
    Pseudonym = 5;
}

enum FreezeState : u8 {
    Active = 0;
    RecoveryPending = 1;
    Frozen = 2;
}

struct Principal @type_tag(0x0020) @version(1) @max_bytes(282) {
    principal_id: PrincipalId;
    principal_kind: PrincipalKind;
    controller_policy_hash: Digest384;
    recovery_policy_hash: Digest384;
    authenticator_set_root: Digest384;
    sequence: u64;
    freeze_state: FreezeState;
    metadata_commitment: Digest384;
    anchor_deposit: Amount;
    created_at: Height;
    last_updated_at: Height;
}

enum CryptoFamily : u8 {
    MlDsa = 1;
    SlhDsaShake = 2;
    MlKem = 3;
    Shake = 4;
}

struct CryptoSuiteId {
    family: CryptoFamily;
    parameter_set: u16;
    encoding_version: u16;
    security_profile: u8;
}

enum AuthenticatorPurpose : u8 {
    Control = 0;
    Recovery = 1;
    Session = 2;
    Validator = 3;
    CredentialIssuance = 4;
    ToolReceipt = 5;
}

struct AuthenticatorDescriptor @type_tag(0x0021) @version(1) @max_bytes(4179) {
    authenticator_id: AuthenticatorId;
    scheme: CryptoSuiteId;
    verification_key: bytes<4096>;
    purpose: AuthenticatorPurpose;
    valid_from: Height;
    valid_until: Option<Height>;
    revoked_at: Option<Height>;
}

struct RecoveryRequest @type_tag(0x0022) @version(1) @max_bytes(232) {
    principal_id: PrincipalId;
    expected_sequence: u64;
    proposed_controller_policy_hash: Digest384;
    proposed_authenticator_set_root: Digest384;
    recovery_evidence_commitment: Digest384;
    initiated_at: Height;
    challenge_deadline: Height;
    recovery_bond: Amount;
}

enum ScopeSelector : u8 {
    Any = 0;
    Exact(value: Digest384) = 1;
    Prefix(bits: u16, bytes: Digest384) = 2;
}

newtype ResourceSelector = ScopeSelector;
newtype DataSelector = ScopeSelector;

enum HolderBinding : u8 {
    Principal(principal_id: PrincipalId) = 0;
    Private(commitment: Digest384) = 1;
    Bearer = 2;
}

struct RateLimit {
    maximum_uses: u64;
    window_blocks: u64;
}

struct ProtocolSignature @max_bytes(20011) {
    suite: CryptoSuiteId;
    bytes: bytes<20000>;
}

struct CapabilityGrant @type_tag(0x0030) @version(1) @max_bytes(22024) {
    capability_id: CapabilityId;
    issuer: PrincipalId;
    holder_binding: HolderBinding;
    parent_capability: Option<CapabilityId>;
    permitted_actions: BoundedSet<ActionId, 32>;
    resource_scope: ResourceSelector;
    data_scope: DataSelector;
    monetary_limit: Option<Amount>;
    compute_limit: Option<ResourceUnits>;
    rate_limit: Option<RateLimit>;
    use_limit: Option<u64>;
    valid_from: Height;
    valid_until: Option<Height>;
    delegation_depth_remaining: u8;
    delegation_allowed: bool;
    revocation_registry: Option<ObjectId>;
    constraint_hash: Digest384;
    issuer_signature: ProtocolSignature;
}

enum ActorBinding : u8 {
    Principal(principal_id: PrincipalId) = 0;
    Private(commitment: Digest384) = 1;
}

enum PolicyEffect : u8 {
    Permit = 0;
    Forbid = 1;
}

enum PolicyPredicate : u8 {
    ActorIs(actor: ActorBinding) = 0;
    ActionIs(action: ActionId) = 1;
    ResourceMatches(selector: ResourceSelector) = 2;
    ValueAtMost(value: Amount) = 3;
    ValueAtLeast(value: Amount) = 4;
    HeightAtLeast(height: Height) = 5;
    HeightAtMost(height: Height) = 6;
    HasCredentialSchema(schema: Digest384) = 7;
    HasCapability(capability_id: CapabilityId) = 8;
    ApprovalCountAtLeast(role: Digest384, minimum: u8) = 9;
    FreezeStateIs(freeze_state: FreezeState) = 10;
    DeclaredPurposeIs(purpose: Digest384) = 11;
}

enum PolicyObligation : u8 @max_bytes(65) {
    DecrementCapabilityBudget(capability_id: CapabilityId, amount: Amount) = 0;
    ConsumeCapability(capability_id: CapabilityId) = 1;
    EmitAuditCommitment(commitment: Digest384) = 2;
    RequireApproval(role: Digest384, minimum: u8) = 3;
    DelaySettlementUntil(height: Height) = 4;
    RestrictOutputDisclosure(policy_hash: Digest384) = 5;
}

struct PolicyRule {
    effect: PolicyEffect;
    predicates: BoundedList<PolicyPredicate, 16>;
    obligations: BoundedList<PolicyObligation, 4>;
}

struct PolicySet @type_tag(0x0040) @version(1) @max_bytes(35043) {
    language_version: u16;
    rules: BoundedList<PolicyRule, 32>;
}

struct ApprovalFact {
    role: Digest384;
    count: u8;
}

struct PolicyRequest @type_tag(0x0041) @version(1) @max_bytes(4078) {
    actor: ActorBinding;
    action: ActionId;
    resource: ObjectId;
    height: Height;
    value: Amount;
    freeze_state: FreezeState;
    declared_purpose: Option<Digest384>;
    credential_schemas: BoundedSet<Digest384, 32>;
    capabilities: BoundedSet<CapabilityId, 32>;
    approvals: BoundedMap<Digest384, u8, 16>;
}

enum DecisionResult : u8 {
    Deny = 0;
    Permit = 1;
}

struct PolicyDecision @type_tag(0x0042) @version(1) @max_bytes(8327) {
    result: DecisionResult;
    matched_permit_rules: u8;
    matched_forbid_rules: u8;
    steps_used: u16;
    obligations: BoundedList<PolicyObligation, 128>;
}

enum ObjectOwner : u8 {
    Principal(principal_id: PrincipalId) = 0;
    Shared = 1;
    Immutable = 2;
    CapabilityControlled(capability_id: CapabilityId) = 3;
    Shielded(commitment: Digest384) = 4;
}

newtype ObjectFlags = u16;

struct Object @type_tag(0x0050) @version(1) @max_bytes(16856) {
    object_id: ObjectId;
    object_version: u64;
    type_id: Digest384;
    owner: ObjectOwner;
    control_policy_hash: Digest384;
    use_policy_hash: Digest384;
    disclosure_policy_hash: Digest384;
    upgrade_policy_hash: Digest384;
    package_id: Option<PackageId>;
    value_root: Digest384;
    public_value: Option<bytes<16384>>;
    lease_expiry_epoch: Epoch;
    storage_deposit: Amount;
    flags: ObjectFlags;
}

struct ObjectVersionRef {
    object_id: ObjectId;
    version: u64;
}

struct NamespaceGrant @max_bytes(99) {
    namespace: ResourceSelector;
    capability_id: CapabilityId;
}

struct AccessManifest @type_tag(0x0051) @version(1) @max_bytes(10093) {
    exact_reads: BoundedSet<ObjectVersionRef, 64>;
    exact_writes: BoundedSet<ObjectVersionRef, 32>;
    immutable_reads: BoundedSet<ObjectId, 64>;
    creation_namespaces: BoundedSet<NamespaceGrant, 16>;
    maximum_created_objects: u32;
    maximum_dynamic_reads: u32;
    dynamic_read_policy: Option<Digest384>;
}

struct TransferCommand @max_bytes(39226) {
    input: ObjectVersionRef;
    new_owner: ObjectOwner;
    control_policy: PolicySet;
    request: PolicyRequest;
}

struct TransferTransaction @type_tag(0x0052) @version(1) @max_bytes(1265334) {
    height: Height;
    access_manifest: AccessManifest;
    commands: BoundedList<TransferCommand, 32>;
}

enum ReceiptResult : u8 {
    Success = 0;
    RequestContextMismatch = 1;
    AccessManifestViolation = 2;
    ObjectNotFound = 3;
    StaleObjectVersion = 4;
    ControlPolicyMismatch = 5;
    AuthorizationDenied = 6;
    UnsupportedObligation = 7;
    ImmutableObject = 8;
    TransferDisabled = 9;
    OwnerUnchanged = 10;
    VersionExhausted = 11;
}

struct TransitionReceipt @type_tag(0x0053) @version(1) @max_bytes(104) {
    result: ReceiptResult;
    failed_command: Option<u8>;
    objects_updated: u8;
    policy_steps: u32;
    pre_state_commitment: Digest384;
    post_state_commitment: Digest384;
}

struct ObjectState @type_tag(0x0054) @version(1) @max_bytes(1078785) {
    objects: BoundedSet<Object, 64>;
}

enum StateProofKind : u8 {
    Membership = 0;
    NonMembership = 1;
}

struct StateProofLevel {
    sibling_bitmap: u16;
    siblings: BitmapValues<Digest384, 16>;
}

struct StateProof @type_tag(0x0055) @version(1) @max_bytes(69361) {
    kind: StateProofKind;
    object_id: ObjectId;
    levels: FixedList<StateProofLevel, 96>;
}

struct StateCommitment @type_tag(0x0056) @version(1) @max_bytes(56) {
    root: Digest384;
    object_count: u64;
}

enum VmValueType : u8 {
    U64 = 0;
    Bool = 1;
    Digest = 2;
    Object = 3;
    Capability = 4;
}

enum VmInstruction : u8 @max_bytes(50) {
    LoadU64(destination: u8, value: u64) = 0;
    LoadBool(destination: u8, value: bool) = 1;
    LoadDigest(destination: u8, value: Digest384) = 2;
    Copy(destination: u8, source: u8) = 3;
    Move(destination: u8, source: u8) = 4;
    AddU64(destination: u8, left: u8, right: u8) = 5;
    EqU64(destination: u8, left: u8, right: u8) = 6;
    Jump(target: u16) = 7;
    BranchIf(condition: u8, target: u16) = 8;
    ConsumeCapability(source: u8) = 9;
    Emit(source: u8) = 10;
    Return(sources: BoundedList<u8, 16>) = 11;
}

struct VmProgram @type_tag(0x0060) @version(1) @max_bytes(12854) {
    input_count: u8;
    register_types: BoundedList<VmValueType, 32>;
    output_types: BoundedList<VmValueType, 16>;
    instructions: BoundedList<VmInstruction, 256>;
    maximum_events: u8;
}

enum VmValue : u8 @max_bytes(16857) {
    U64(value: u64) = 0;
    Bool(value: bool) = 1;
    Digest(value: Digest384) = 2;
    Object(value: Object) = 3;
    Capability(value: CapabilityId) = 4;
}

enum VmEventValue : u8 @max_bytes(49) {
    U64(value: u64) = 0;
    Bool(value: bool) = 1;
    Digest(value: Digest384) = 2;
}

struct VmExecutionResult @type_tag(0x0061) @version(1) @max_bytes(270508) {
    gas_used: u64;
    steps: u16;
    outputs: BoundedList<VmValue, 16>;
    events: BoundedList<VmEventValue, 16>;
}
